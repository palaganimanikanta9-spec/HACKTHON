    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.1.0",
    "pino-pretty": "^11.1.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.12",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.2",
