{
  "name": "smartsave-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/web\" \"npm run dev --workspace=server\"",
    "build": "npm run prisma:generate --workspace=server && npm run build --workspace=server && npm run build --workspace=apps/web",
    "start": "concurrently \"npm run start --workspace=apps/web\" \"npm run start --workspace=server\""
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "@clerk/backend": "^1.24.1",
    "@clerk/nextjs": "^7.5.20",
    "@prisma/client": "^5.14.0",
    "@tailwindcss/typography": "^0.5.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.6.0",
    "framer-motion": "^12.42.2",
    "helmet": "^8.3.0",
    "lucide-react": "^1.25.0",
    "multer": "^1.4.5-lts.1",
    "next": "15.5.20",
    "next-themes": "^0.4.6",
    "pino": "^9.1.0",
    "pino-pretty": "^11.1.0",
    "react": "19.1.4",
    "react-dom": "19.1.4",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.12",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^5.14.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
